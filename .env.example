# ==========================
# APP
# ==========================
NODE_ENV=development
APP_NAME=Archid Flow Server V4
APP_CODE=archid-flow
API_VERSION=v1
PORT=4000

API_BASE_URL=http://localhost:4000
CLIENT_URL=http://localhost:3000
CORS_ORIGIN=*

# ==========================
# DATABASE
# ==========================
MONGODB_URI=mongodb://127.0.0.1:27017/archid_flow_v4

# ==========================
# JWT
# This will be used from Phase 02 Auth
# ==========================
JWT_SECRET=replace_this_with_strong_secret
JWT_EXPIRES_IN=7d

# ==========================
# MQTT
# This will be used from MQTT phase
# ==========================
MQTT_NAMESPACE=archid
MQTT_API_VERSION=v4

MQTT_URL=mqtt://127.0.0.1:1883
MQTT_USERNAME=backend_user
MQTT_PASSWORD=backend_password
MQTT_RECONNECT_PERIOD=5000
MQTT_CONNECT_TIMEOUT=30000
MQTT_CLEAN=true

MQTT_PUBLIC_URL=wss://mqtt.archidtech.in/mqtt
MQTT_ACCESS_TTL_SECONDS=900

# ==========================
# DEVICE MONITORING
# This will be used from MQTT/offline-monitor phase
# ==========================
DEVICE_OFFLINE_THRESHOLD_SECONDS=60
DEVICE_OFFLINE_CHECK_INTERVAL_SECONDS=30